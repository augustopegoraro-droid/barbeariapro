# BarbeariaPro — produção (taylorethedy.com.br)
# Copiar para .env na VM e preencher todos os campos marcados com <PREENCHER>.
# NUNCA comitar este arquivo com valores reais.

# ── App / JWT ─────────────────────────────────────────────────────────────────
# Gerar: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<PREENCHER>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Banco principal ───────────────────────────────────────────────────────────
# Role do APP (RLS ativo) — usada em runtime pelo FastAPI
DATABASE_URL=postgresql+psycopg://barber_app:<SENHA_APP>@localhost:5432/barbeariapro

# Role ADMIN (dona das tabelas) — usada APENAS por alembic (Dockerfile.migrate)
ADMIN_DATABASE_URL=postgresql+psycopg://barber_owner:<SENHA_OWNER>@localhost:5432/barbeariapro
APP_DB_ROLE=barber_app
SEED_PASSWORD=<SENHA_SEED>

# Postgres superuser (docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<SENHA_POSTGRES>
POSTGRES_DB=barbeariapro

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.taylorethedy.com.br

# ── Bot / n8n ─────────────────────────────────────────────────────────────────
# Gerar: python3 -c "import secrets; print(secrets.token_hex(32))"
BOT_API_KEY=<PREENCHER>
BOT_ORGANIZATION_ID=3
BOT_UNIT_ID=1
ENABLE_DEBUG_ENDPOINTS=false

# ── OpenAI (usado pelo n8n no workflow do chatbot) ────────────────────────────
OPENAI_API_KEY=<PREENCHER>

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────
EVOLUTION_API_KEY=<PREENCHER>
EVOLUTION_POSTGRES_PASSWORD=<PREENCHER>
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=<nome-do-chip-cadastrado-na-evolution>

# ── Google Calendar (Fase 2 — OAuth2) ────────────────────────────────────────
GOOGLE_CLIENT_ID=6349897322-9sm7kq2fu81d6rqec2hnv4toucesvc6g.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<PREENCHER — ver Google Cloud Console>
GOOGLE_REDIRECT_URI=https://api.taylorethedy.com.br/integracoes/google/calendar/callback
GOOGLE_FRONTEND_SUCCESS_URL=https://app.taylorethedy.com.br/admin/configuracoes
# Gerar: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=<PREENCHER>

# ── Build args do frontend (docker-compose.app.yml usa via ${VAR}) ────────────
NEXT_PUBLIC_API_URL=https://api.taylorethedy.com.br
NEXT_PUBLIC_ORG_ID=3
