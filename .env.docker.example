# BarbeariaPro — overrides para execução em container (docker-compose.app.yml)
# Copiar para .env.docker e preencher senhas.
# Os containers acessam a infra publicada no host via host.docker.internal.

# Backend → PostgreSQL (publicado em :5432 no host)
DATABASE_URL=postgresql+psycopg://barber_app:<SENHA_APP>@host.docker.internal:5432/barbeariapro

# Backend → Evolution API (publicada em :8080 no host)
EVOLUTION_API_URL=http://host.docker.internal:8080

# Frontend (SSR / next-auth) → backend via rede interna do host
API_URL_INTERNAL=http://host.docker.internal:8000

# Gerar: python3 -c "import secrets; print(secrets.token_hex(48))"
AUTH_SECRET=<PREENCHER>

# Obrigatório quando rodando atrás de proxy (Nginx)
AUTH_TRUST_HOST=true
