# barbearia-superadmin (container) — copie para .env.superadmin e preencha.
# .env.superadmin é IGNORADO pelo git (.gitignore: .env.*). NUNCA versione segredos.
#
# Além destas, o serviço recebe NEXT_PUBLIC_API_URL como build-arg via
# SUPERADMIN_API_URL (definido no ambiente do `docker compose build`).

# URL interna do backend para chamadas server-side (next-auth authorize / SSR).
# Container alcança o backend publicado no host:
API_URL_INTERNAL=http://host.docker.internal:8000

# Segredo do next-auth. Gere com: openssl rand -base64 32
AUTH_SECRET=troque-por-um-segredo-forte

# Atrás do nginx (proxy), o next-auth precisa confiar no host encaminhado.
AUTH_TRUST_HOST=true
