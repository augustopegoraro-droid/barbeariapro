{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "declaration": false,
    "sourceMap": false,
    "outDir": "dist",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "ts-node": {
    "transpileOnly": false
  },
  "include": ["src/**/*.ts"]
}
