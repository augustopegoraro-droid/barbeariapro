# ─────────────────────────────────────────────────────────────────────
# App / JWT
# ─────────────────────────────────────────────────────────────────────
SECRET_KEY=troque-isto-por-uma-string-aleatoria-bem-longa
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─────────────────────────────────────────────────────────────────────
# Redis (D-68, Fase 3) — rate-limit/lockout de login, tickets de SSE de uso
# único, denylist curta de jti no logout. Dado 100% efêmero (a fonte de
# verdade de sessão é o Postgres, tabela `sessions`).
# ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_DURATION_SECONDS=900
# Desligar só em teste automatizado (ver .env.staging) — nunca em produção.
RATE_LIMIT_ENABLED=true
# /docs, /redoc, /openapi.json — deixar false em produção (V12).
DOCS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────
# Banco — conexão do APP.
# Role NÃO-superuser e NÃO-dona das tabelas: é esta conexão que sofre RLS.
# A APLICAÇÃO lê SOMENTE esta variável.
# ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://barber_app:app_pwd@localhost:5432/barbeariapro

# ─────────────────────────────────────────────────────────────────────
# Usadas APENAS por scripts/seed.py (não pela aplicação).
# Role DONA das tabelas: bypassa a RLS para inserir a organização e
# reaplicar os GRANTs DML à role do app.
# ─────────────────────────────────────────────────────────────────────
ADMIN_DATABASE_URL=postgresql+psycopg://barber_owner:owner_pwd@localhost:5432/barbeariapro
APP_DB_ROLE=barber_app
SEED_PASSWORD=senha123

# ─────────────────────────────────────────────────────────────────────
# Bot / chatbot n8n  (preencher após rodar scripts/seed.py)
# ─────────────────────────────────────────────────────────────────────
BOT_API_KEY=troque-por-chave-segura-longa
BOT_ORGANIZATION_ID=1
BOT_UNIT_ID=1

# Habilita endpoints de debug do bot (ex.: /bot/debounce/debug-set-session).
# Mantenha false em produção; true apenas para rodar scripts/test_t07_t12.py.
ENABLE_DEBUG_ENDPOINTS=false

# ─────────────────────────────────────────────────────────────────────
# Docker Compose — postgres e n8n
# ─────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-em-producao
POSTGRES_DB=barbeariapro

# ─────────────────────────────────────────────────────────────────────
# Evolution API — gateway WhatsApp
# ─────────────────────────────────────────────────────────────────────
EVOLUTION_API_KEY=troque-pela-chave-da-evolution-api
EVOLUTION_POSTGRES_PASSWORD=evolution123
EVOLUTION_SERVER_URL=http://localhost:8080
